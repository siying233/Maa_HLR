    "interface_version": 2,
    "name": "MaaHLR",
    "description": "MaaHLR 海螺肉小助手，开发中~嘿嘿嘿",
    // "contact": "QQ群: 123456789",
    "license": "MIT",
    "welcome": "首次使用！欢迎使用 MAA HLR!",
    // 填写项目地址和版本号可实现自动更新功能
    "github": "https://github.com/siying233/Maa_HLR",
    "version": "1.0.0",
    // Mirror酱为第三方分发服务，新项目默认关闭
    // 若有需要请联系 Mirror酱 开通，直接自行开启是无法使用的
    // "mirrorchyan_rid": "MaaXXX",
    // "mirrorchyan_multiplatform": true,
    "controller": [
        {
            "name": "安卓端",
            "type": "Adb",
            "display_short_side": 720 // 默认缩放分辨率的短边长度
        },
        {
            "name": "桌面端",
            "type": "Win32",
            "win32": {
                "class_regex": ".*",
                "window_regex": "Visual Studio"
            },
            // 截图及控制方式，请根据项目实际情况修改
            // 文档: https://github.com/MaaXYZ/MaaFramework/blob/main/docs/zh_cn/2.4-%E6%8E%A7%E5%88%B6%E6%96%B9%E5%BC%8F%E8%AF%B4%E6%98%8E.md
            "screencap": "PrintWindow", // 截图方式
            "mouse": "PostMessageWithCursorPos", // 鼠标控制方式
            "keyboard": "PostMessageWithCursorPos" // 键盘控制方式
        }
    ],
    "resource": [
        {
            "name": "官服",
            "path": [
                "{PROJECT_DIR}/resource"
            ]
        }
